# Telegram bot token (from @BotFather)
TELEGRAM_BOT_TOKEN=

# One forum supergroup with three topics. SUPERGROUP_ID is the supergroup chat id
# (negative, e.g. -1001234567890). The TOPIC ids are the forum topic thread ids.
TELEGRAM_SUPERGROUP_ID=
TELEGRAM_TOPIC_PERSONAL=
TELEGRAM_TOPIC_ACADEMIC=
TELEGRAM_TOPIC_WORK=

# Canvas
CANVAS_BASE_URL=
CANVAS_API_TOKEN=

# Outlook .pst (Docker). The daily export lands on your Windows Desktop, but the
# container is Linux — so docker-compose bind-mounts the folder holding the .pst
# (read-only) at /data/pst. Set OUTLOOK_PST_DIR to that host folder, and point
# OUTLOOK_PST_PATH at the file *inside the container*.
OUTLOOK_PST_DIR=C:\Users\you\Desktop
OUTLOOK_PST_PATH=/data/pst/outlook-export.pst

# Hub location. Under Docker this is pinned to /app/hub by docker-compose and the
# host folder ./hub is bind-mounted there; leave blank for non-container runs.
HUB_DIR=

# Claude Code login (NOT an API key). Mint on this host with:
#   claude setup-token
# then paste it here. Re-mint when auth starts failing.
CLAUDE_CODE_OAUTH_TOKEN=

# Optional model override (default claude-opus-4-8[1m])
#CLAUDE_MODEL=

# pino log level
LOG_LEVEL=info
