# Telegram bot token (from @BotFather)
TELEGRAM_BOT_TOKEN=

# The three channel chat IDs. Add the bot to each chat and read the id
# (e.g. via @RawDataBot). Negative for groups/supergroups.
TELEGRAM_CHANNEL_PERSONAL=
TELEGRAM_CHANNEL_ACADEMIC=
TELEGRAM_CHANNEL_WORK=

# Canvas
CANVAS_BASE_URL=
CANVAS_API_TOKEN=

# Outlook: path to the daily .pst export on your Desktop
OUTLOOK_PST_PATH=C:\Users\jeonw\Desktop\outlook-export.pst

# Hub location (default: <project>/hub). Leave blank to use the default.
HUB_DIR=

# Claude Code login (NOT an API key). Mint on this host with:
#   claude setup-token
# then paste it here. Re-mint when auth starts failing.
CLAUDE_CODE_OAUTH_TOKEN=

# Optional model override (default claude-opus-4-8[1m])
#CLAUDE_MODEL=

# pino log level
LOG_LEVEL=info
