# Telegram bot — create via @BotFather
TELEGRAM_BOT_TOKEN=

# The numeric Telegram user id allowed to DM this bot. Anyone else is
# ignored. Leave empty to bootstrap: any DM you send while empty replies
# with your user id; paste it here and restart.
OPERATOR_USER_ID=

# Where source files (Telegram attachments) are stored. data/raw is symlinked
# to this path so the files stay browsable outside the repo. On WSL, point it
# at your Windows Desktop, e.g. /mnt/c/Users/<you>/Desktop/icarus-raw. If the
# parent path doesn't exist, icarus falls back to a local data/raw directory.
# Defaults to /mnt/c/Users/jeonw/Desktop/icarus-raw.
RAW_DIR=

# IANA timezone for log timestamps (e.g. America/Los_Angeles). Defaults to UTC.
TZ=UTC

# pino log level: trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# Sandbox the per-turn claude subprocess with bubblewrap so it can only write
# data/ and the raw/ tree (everything else, incl. src/, is read-only). auto
# (default) = on when bwrap is available on Linux; on = require bwrap, error if
# missing; off = disable.
AGENT_SANDBOX=auto
