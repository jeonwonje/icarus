# Telegram bot — create via @BotFather
TELEGRAM_BOT_TOKEN=

# Supergroup chat ID. Negative for supergroups (e.g. -1001234567890).
# Use /chatid inside the group to print it once the bot is added.
TELEGRAM_CHAT_ID=

# IANA timezone for log timestamps (e.g. America/Los_Angeles). Defaults to UTC.
TZ=UTC

# pino log level: trace | debug | info | warn | error | fatal
LOG_LEVEL=info
