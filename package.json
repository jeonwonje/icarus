{
  "name": "icarus",
  "version": "0.1.0",
  "description": "Telegram-driven per-thread wiki agent. Each forum topic is its own compounding markdown knowledge base.",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "clean": "rm -rf dist",
    "build": "npm run clean && tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "prune:weekly": "tsx scripts/weekly-prune.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@grammyjs/runner": "^2.0.3",
    "better-sqlite3": "^11.10.0",
    "grammy": "^1.41.1",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=20"
  }
}
